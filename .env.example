# ERICA Environment Configuration Template
# Copy this file to .env and configure for your environment

# Node Environment
NODE_ENV=development
# Set to 'production' for optimized builds

# Logging
LOG_LEVEL=info
# Options: debug, info, warn, error

# API Server Port
PORT=3001
# Port on which the API server listens

# Web Frontend Port
WEB_PORT=3000
# Port for the frontend (served by API in production)

# API Base URL
# Used by the frontend to determine where to send API requests
# In development: http://localhost:3001
# In production: https://yourdomain.com (set this in your deployment)
API_BASE_URL=http://localhost:3001

# HTTPS Enforcement (future use)
# FORCE_HTTPS=false
# Set to true in production to enforce HTTPS

# Debugging
# DEBUG=erica:*
# Uncomment to enable detailed debug logging

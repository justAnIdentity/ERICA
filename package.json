{
  "name": "eudi-vp-debugger",
  "version": "0.0.1",
  "description": "Public web-based debugging tool for OpenID4VP Presentation Requests and Responses, supporting EUDI Wallet Architecture & Reference Framework",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:core && npm run build:api && npm run build:web",
    "build:core": "tsc",
    "build:api": "cd api && npm run build",
    "build:web": "cd web && npm run build",
    "dev": "npm run dev:core & npm run dev:api & npm run dev:web",
    "dev:core": "tsc --watch",
    "dev:api": "cd api && npm run dev",
    "dev:web": "cd web && npm run dev",
    "test": "npm run build:core && node --test dist/tests/**/*.test.js",
    "test:unit": "npm run build:core && node --test dist/tests/unit/*.test.js",
    "test:integration": "npm run build:core && node --test dist/tests/integration/*.test.js",
    "test:debug": "npm run build:core && node --test dist/tests/debug/*.test.js",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist && cd api && npm run clean && cd ../web && rm -rf dist && cd .."
  },
  "keywords": [
    "openid4vp",
    "verifiable-credentials",
    "sd-jwt",
    "iso-mdoc",
    "eudi-wallet",
    "debugging"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@credo-ts/core": "^0.6.2",
    "@credo-ts/node": "^0.6.2",
    "@credo-ts/openid4vc": "^0.6.2",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "typescript": "^5.3.0"
  }
}

{
  "name": "eudi-vp-debugger-api",
  "version": "0.0.1",
  "description": "Express API for EUDI VP Debugger",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run build:core && tsc",
    "build:core": "cd .. && npm run build:core",
    "dev": "npm run build:core && tsx watch src/server.ts",
    "start": "node dist/server.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  }
}
